{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "semanticCommits": "enabled",
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "description": "Group GitHub Actions digest updates and apply a 7-day stabilisation period",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["digest"],
      "minimumReleaseAge": "7 days",
      "groupName": "github-actions digest updates"
    },
    {
      "description": "Apply a 7-day stabilisation period for GitHub Actions major/minor/patch updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Skip stabilisation period for critical security updates to GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchCategories": ["security"],
      "minimumReleaseAge": "0 days"
    }
  ]
}
